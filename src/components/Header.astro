---
import config from '../../config.json';
import OfferBanner from './OfferBanner.astro';
---

<OfferBanner />

<header class="header" id="mainHeader">
  <div class="container">
    <div class="header-content">
      <a href="/" class="logo">
        <img src="/assets/images/general/All Seasons Living SVG Logo.svg" alt="All Seasons Living" class="logo-img" />
      </a>

      <nav class="nav" id="mainNav">
        <ul class="nav-menu">
          <li><a href="/">Home</a></li>
          <li class="has-dropdown">
            <a href="#" class="dropdown-toggle">
              Products
              <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M6 9L1 4h10L6 9z"/></svg>
            </a>
            <ul class="dropdown-menu">
              <li><a href="/outdoor-blinds">Outdoor Blinds</a></li>
              <li><a href="/roller-shutters">Roller Shutters</a></li>
              <li><a href="/artificial-lawn">Artificial Lawn</a></li>
            </ul>
          </li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <div class="header-actions">
        <a href={`tel:${config.contact.phone.replace(/[\s()]/g, '')}`} class="header-phone" data-location="header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          <span class="phone-text">{config.contact.phone}</span>
        </a>
        <button class="btn btn-primary header-quote-btn" id="quoteBtn">Free Quote</button>
      </div>

      <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<style>
  /* ============================
     BASE — Transparent overlay
     ============================ */
  .header {
    position: fixed;
    top: var(--banner-height, 0px);
    left: 0;
    right: 0;
    z-index: 9000;
    background: transparent;
    transition: background 0.35s ease, box-shadow 0.35s ease, top 0.35s ease;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 0;
    gap: 1rem;
  }

  /* Logo */
  .logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    z-index: 2;
  }

  .logo-img {
    height: 48px;
    width: auto;
    filter: brightness(0) invert(1);
    transition: filter 0.35s ease, height 0.35s ease;
  }

  /* Nav */
  .nav {
    display: none;
  }

  .nav-menu {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-menu > li > a {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    color: var(--white);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
    white-space: nowrap;
  }

  .nav-menu > li > a:hover {
    background: rgba(255,255,255,0.12);
  }

  .nav-menu > li > a.active {
    background: rgba(255,255,255,0.15);
  }

  /* Dropdown */
  .has-dropdown {
    position: relative;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    background: var(--white);
    box-shadow: 0 8px 32px rgba(0,0,0,0.15);
    border-radius: var(--radius-sm);
    padding: 0.375rem 0;
    min-width: 200px;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    z-index: 9003;
  }

  .has-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
  }

  .dropdown-menu li a {
    display: block;
    padding: 0.75rem 1.25rem;
    color: var(--black);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .dropdown-menu li a:hover {
    background: var(--light-sage);
    color: var(--olive-green);
  }

  /* Header Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .header-phone {
    display: none;
    align-items: center;
    gap: 0.5rem;
    color: var(--white);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: color 0.2s ease, opacity 0.2s ease;
    white-space: nowrap;
  }

  .header-phone:hover {
    opacity: 0.8;
    color: var(--white);
  }

  .header-quote-btn {
    padding: 0.625rem 1.5rem !important;
    font-size: 0.875rem !important;
    min-height: auto !important;
    border-radius: 6px;
  }

  /* Mobile toggle */
  .mobile-menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    min-height: 44px;
    min-width: 44px;
    z-index: 9005;
  }

  .mobile-menu-toggle span {
    width: 24px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .mobile-menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* ============================
     SCROLLED STATE — Solid background
     ============================ */
  .header.scrolled {
    background: var(--white);
    box-shadow: 0 1px 8px rgba(0,0,0,0.08);
  }

  .header.scrolled .logo-img {
    filter: none;
    height: 42px;
  }

  .header.scrolled .nav-menu > li > a {
    color: var(--black);
  }

  .header.scrolled .nav-menu > li > a:hover {
    background: var(--light-sage);
    color: var(--olive-green);
  }

  .header.scrolled .nav-menu > li > a.active {
    color: var(--olive-green);
    background: var(--light-sage);
  }

  .header.scrolled .header-phone {
    color: var(--black);
  }

  .header.scrolled .header-phone:hover {
    color: var(--olive-green);
    opacity: 1;
  }

  .header.scrolled .mobile-menu-toggle span {
    background: var(--black);
  }

  .header.scrolled .header-content {
    padding: 0.5rem 0;
  }

  /* ============================
     MOBILE NAV OVERLAY (< 1025px)
     ============================ */
  .nav.mobile-active {
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--white);
    z-index: 9004;
    padding: 5rem 1.5rem 2rem;
    overflow-y: auto;
  }

  .nav.mobile-active .nav-menu {
    flex-direction: column;
    gap: 0;
  }

  .nav.mobile-active .nav-menu > li > a {
    color: var(--black);
    padding: 1rem 0;
    font-size: 1.125rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    border-radius: 0;
  }

  .nav.mobile-active .nav-menu > li > a:hover,
  .nav.mobile-active .nav-menu > li > a.active {
    color: var(--olive-green);
    background: none;
  }

  .nav.mobile-active .dropdown-menu {
    position: static;
    transform: none;
    box-shadow: none;
    background: transparent;
    padding: 0;
    opacity: 1;
    visibility: visible;
    min-width: 0;
  }

  .nav.mobile-active .dropdown-menu li a {
    padding: 0.75rem 0 0.75rem 1.5rem;
    font-size: 1rem;
    color: var(--black);
    opacity: 0.75;
  }

  .nav.mobile-active .dropdown-menu li a:hover {
    color: var(--olive-green);
    background: none;
    opacity: 1;
  }

  /* When mobile nav is open, toggle is always dark */
  .mobile-menu-toggle.active span {
    background: var(--black) !important;
  }

  /* ============================
     TABLET & DESKTOP (768px+)
     ============================ */
  @media (min-width: 768px) {
    .header-phone {
      display: flex;
    }
  }

  /* ============================
     DESKTOP (1025px+)
     ============================ */
  @media (min-width: 1025px) {
    .header-content {
      padding: 1rem 0;
    }

    .logo-img {
      height: 56px;
    }

    .nav {
      display: flex;
      align-items: center;
    }

    .mobile-menu-toggle {
      display: none;
    }

    .header-phone {
      display: flex;
    }

    .phone-text {
      display: inline;
    }

    .header.scrolled .header-content {
      padding: 0.5rem 0;
    }

    .header.scrolled .logo-img {
      height: 44px;
    }
  }
</style>

<script>
  const header = document.getElementById('mainHeader');
  const nav = document.getElementById('mainNav');
  const mobileToggle = document.getElementById('mobileMenuToggle');

  // Scroll handler — toggle transparent/solid header
  let ticking = false;

  function handleScroll() {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

    if (scrollTop > 80) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }

    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(handleScroll);
      ticking = true;
    }
  }, { passive: true });

  // Initial check
  handleScroll();

  // Mobile menu toggle
  if (mobileToggle && nav) {
    mobileToggle.addEventListener('click', () => {
      const isActive = nav.classList.toggle('mobile-active');
      mobileToggle.classList.toggle('active');
      document.body.style.overflow = isActive ? 'hidden' : '';
    });
  }

  // Mobile dropdown toggle
  const dropdownToggles = document.querySelectorAll('.dropdown-toggle');
  dropdownToggles.forEach(toggle => {
    toggle.addEventListener('click', (e) => {
      if (window.innerWidth < 1025) {
        e.preventDefault();
        const parent = toggle.closest('.has-dropdown');
        parent?.classList.toggle('active');
      }
    });
  });

  // Close mobile menu on nav link click
  nav?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest('a:not(.dropdown-toggle)');
    if (link && link.getAttribute('href') !== '#') {
      nav.classList.remove('mobile-active');
      mobileToggle?.classList.remove('active');
      document.body.style.overflow = '';
    }
  });

  // Close on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1025 && nav) {
      nav.classList.remove('mobile-active');
      mobileToggle?.classList.remove('active');
      document.body.style.overflow = '';
    }
  });

  // Active page detection
  const currentPath = window.location.pathname;
  const navLinks = document.querySelectorAll('.nav-menu > li > a:not(.dropdown-toggle)');
  navLinks.forEach(link => {
    const href = link.getAttribute('href');
    if (href === currentPath || (currentPath === '/' && href === '/')) {
      link.classList.add('active');
    }
  });
</script>
