---
/**
 * Google Reviews Carousel
 * Fetches live reviews from Google Places API (New) at render time.
 * CSS scroll-snap carousel — swipeable on mobile, arrow nav on desktop.
 */

interface GoogleReview {
  rating: number
  text?: { text: string }
  relativePublishTimeDescription: string
  authorAttribution: {
    displayName: string
    photoUri?: string
  }
}

interface PlaceDetails {
  rating?: number
  userRatingCount?: number
  reviews?: GoogleReview[]
}

const GOOGLE_PLACES_API_KEY = import.meta.env.GOOGLE_PLACES_API_KEY
const GOOGLE_PLACE_ID = import.meta.env.GOOGLE_PLACE_ID

let reviews: { name: string; rating: number; text: string; timeAgo: string; photoUri?: string }[] = []
let overallRating = 5
let reviewCount = 0

try {
  const res = await fetch(
    `https://places.googleapis.com/v1/places/${GOOGLE_PLACE_ID}?languageCode=en`,
    {
      headers: {
        'X-Goog-Api-Key': GOOGLE_PLACES_API_KEY,
        'X-Goog-FieldMask': 'rating,userRatingCount,reviews',
      },
    }
  )

  if (res.ok) {
    const data: PlaceDetails = await res.json()
    overallRating = data.rating ?? 5
    reviewCount = data.userRatingCount ?? 0

    if (data.reviews) {
      reviews = data.reviews
        .filter((r) => r.text?.text && r.rating >= 4)
        .filter((r) => r.authorAttribution.displayName !== 'Jandrie Lombard')
        .map((r) => ({
          name: r.authorAttribution.displayName,
          rating: r.rating,
          text: r.text!.text,
          timeAgo: r.relativePublishTimeDescription,
          photoUri: r.authorAttribution.photoUri,
        }))
    }
  }
} catch (e) {
  // Silently fail — carousel will be hidden if no reviews
}

// Pinned reviews that should always appear (e.g. reviews with photos not returned by API)
const pinnedReviews = [
  {
    name: 'Courtney Webster',
    rating: 5,
    text: 'All Seasons did a wonderful job at our early learning centre, transforming our outdoor deck into a beautiful grassed play space for the babies. Dane was efficient, and ensured everything was completed in a timely manner.',
    timeAgo: '3 months ago',
  },
]

// Add pinned reviews that aren't already in the API results
for (const pinned of pinnedReviews) {
  if (!reviews.some((r) => r.name === pinned.name)) {
    reviews.push(pinned)
  }
}

const googleBusinessUrl = `https://search.google.com/local/reviews?placeid=${GOOGLE_PLACE_ID}`
const hasReviews = reviews.length > 0
---

{hasReviews && (
  <section class="reviews-section">
    <div class="container">
      <div class="section-header">
        <div class="reviews-header-row">
          <div>
            <h2>Happy Customers</h2>
            <p>See why Canberra homeowners rate us {overallRating} stars on Google.</p>
          </div>
          <a href={googleBusinessUrl} target="_blank" rel="noopener noreferrer" class="google-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span class="google-rating-text">
              <strong>{overallRating}</strong> rating
            </span>
            <span class="google-review-count">{reviewCount} reviews</span>
          </a>
        </div>
      </div>

      <div class="reviews-track" id="reviewsTrack">
        {reviews.map((review) => (
          <div class="review-card">
            <div class="review-header">
              {review.photoUri ? (
                <img
                  src={review.photoUri}
                  alt={review.name}
                  class="review-avatar-img"
                  width="40"
                  height="40"
                  loading="lazy"
                />
              ) : (
                <div class="review-avatar">{review.name.charAt(0)}</div>
              )}
              <div>
                <div class="review-name">{review.name}</div>
                <div class="review-meta">{review.timeAgo}</div>
              </div>
              <svg class="review-google-icon" width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>
            <div class="review-stars">
              {Array.from({ length: review.rating }).map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#FBBC05"/>
                </svg>
              ))}
            </div>
            <p class="review-text">{review.text}</p>
          </div>
        ))}
      </div>

      <!-- Navigation arrows -->
      <div class="reviews-nav">
        <button class="reviews-nav-btn reviews-prev" id="reviewsPrev" aria-label="Previous reviews">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="reviews-nav-btn reviews-next" id="reviewsNext" aria-label="Next reviews">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>
)}

<style>
  .reviews-section {
    padding: 4rem 0;
    background: var(--white);
    overflow: hidden;
  }

  .reviews-header-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .reviews-header-row > div {
    text-align: center;
  }

  .google-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    background: var(--white);
    border: 2px solid rgba(0,0,0,0.08);
    border-radius: var(--radius-full);
    padding: 0.5rem 1.25rem;
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  .google-link:hover {
    border-color: rgba(0,0,0,0.15);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transform: translateY(-1px);
  }

  .google-rating-text {
    font-size: 0.9375rem;
    color: var(--black);
  }

  .google-rating-text strong {
    font-weight: 700;
  }

  .google-review-count {
    font-size: 0.8125rem;
    color: #4285F4;
    font-weight: 600;
  }

  /* Scroll-snap carousel track */
  .reviews-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 0.5rem 0 1.5rem;
    scrollbar-width: none;
  }

  .reviews-track::-webkit-scrollbar {
    display: none;
  }

  .review-card {
    flex: 0 0 calc(100% - 1rem);
    scroll-snap-align: start;
    background: var(--white);
    border: 2px solid rgba(90,110,69,0.08);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
    min-height: 200px;
    display: flex;
    flex-direction: column;
  }

  .review-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .review-avatar,
  .review-avatar-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .review-avatar {
    background: linear-gradient(135deg, var(--olive-green) 0%, #4a5d38 100%);
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
  }

  .review-avatar-img {
    object-fit: cover;
  }

  .review-name {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--black);
    line-height: 1.2;
  }

  .review-meta {
    font-size: 0.8125rem;
    color: rgba(0,0,0,0.5);
  }

  .review-google-icon {
    margin-left: auto;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .review-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 0.75rem;
  }

  .review-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--black);
    opacity: 0.9;
    flex: 1;
    margin: 0;
  }

  /* Navigation buttons */
  .reviews-nav {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .reviews-nav-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid rgba(90,110,69,0.15);
    background: var(--white);
    color: var(--olive-green);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .reviews-nav-btn:hover {
    background: var(--olive-green);
    color: var(--white);
    border-color: var(--olive-green);
  }

  /* Tablet: show 2 cards */
  @media (min-width: 768px) {
    .reviews-header-row {
      flex-direction: row;
      justify-content: space-between;
    }

    .reviews-header-row > div {
      text-align: left;
    }

    .review-card {
      flex: 0 0 calc(50% - 0.75rem);
    }
  }

  /* Desktop: show 3 cards */
  @media (min-width: 1025px) {
    .review-card {
      flex: 0 0 calc(33.333% - 1rem);
    }
  }
</style>

<script>
  const track = document.getElementById('reviewsTrack');
  const prevBtn = document.getElementById('reviewsPrev');
  const nextBtn = document.getElementById('reviewsNext');

  if (track && prevBtn && nextBtn) {
    const getScrollAmount = () => {
      const card = track.querySelector('.review-card') as HTMLElement;
      if (!card) return 300;
      return card.offsetWidth + 20;
    };

    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });
  }
</script>
