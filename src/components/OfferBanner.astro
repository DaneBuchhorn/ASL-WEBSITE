---
import config from '../../config.json';

const { offerBanner } = config;
---

{offerBanner.enabled && (
  <div class="offer-banner" id="offerBanner">
    <div class="container">
      <div class="banner-content">
        <span class="offer-badge">{offerBanner.badge}</span>
        <p class="offer-headline">{offerBanner.headline}</p>
        <a href={offerBanner.link} class="offer-cta-btn">
          {offerBanner.cta}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <button class="close-banner" id="closeBanner" aria-label="Close promotional banner">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>
)}

<style>
  .offer-banner {
    background: linear-gradient(to right, #7C3A1E, #B85C2A, #C8792A, #A0522D);
    padding: 0.625rem 0;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9001;
    color: var(--white);
    transition: transform 0.35s ease;
  }

  .offer-banner.banner-hidden {
    transform: translateY(-100%);
  }

  .banner-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    position: relative;
    padding-right: 2.5rem;
  }

  .offer-badge {
    display: inline-block;
    background: #F5E6C8;
    color: #7C3A1E;
    font-size: 0.625rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .offer-headline {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0;
    white-space: nowrap;
    color: var(--white);
  }

  .offer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: rgba(255,255,255,0.15);
    color: var(--white);
    padding: 0.375rem 0.875rem;
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s ease;
    border: 1px solid rgba(255,255,255,0.25);
  }

  .offer-cta-btn:hover {
    background: rgba(255,255,255,0.25);
    color: var(--white);
  }

  .offer-cta-btn svg {
    transition: transform 0.2s ease;
  }

  .offer-cta-btn:hover svg {
    transform: translateX(2px);
  }

  .close-banner {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .close-banner:hover {
    color: var(--white);
    background: rgba(255,255,255,0.1);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .offer-banner {
      padding: 0.5rem 0;
    }

    .banner-content {
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: center;
      padding-right: 2rem;
    }

    .offer-badge {
      font-size: 0.5625rem;
      padding: 0.2rem 0.5rem;
    }

    .offer-headline {
      font-size: 0.8125rem;
      white-space: normal;
      text-align: center;
    }

    .offer-cta-btn {
      font-size: 0.75rem;
      padding: 0.3rem 0.625rem;
    }
  }

  /* Very small screens */
  @media (max-width: 480px) {
    .offer-headline {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  const closeBanner = document.getElementById('closeBanner');
  const offerBanner = document.getElementById('offerBanner');
  const mainHeader = document.getElementById('mainHeader');

  function updateBannerHeight() {
    if (offerBanner && offerBanner.style.display !== 'none') {
      const h = offerBanner.offsetHeight;
      document.documentElement.style.setProperty('--banner-height', h + 'px');
    } else {
      document.documentElement.style.setProperty('--banner-height', '0px');
    }
  }

  // Check if banner was already dismissed this session
  if (offerBanner && sessionStorage.getItem('offerBannerDismissed') === 'true') {
    offerBanner.style.display = 'none';
    document.documentElement.style.setProperty('--banner-height', '0px');
  } else {
    updateBannerHeight();
  }

  // Hide banner on scroll, show when scrolled back to top
  let bannerTicking = false;
  window.addEventListener('scroll', () => {
    if (!bannerTicking) {
      window.requestAnimationFrame(() => {
        if (!offerBanner || offerBanner.style.display === 'none') { bannerTicking = false; return; }
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        if (scrollTop > 80) {
          offerBanner.classList.add('banner-hidden');
          if (mainHeader) mainHeader.style.top = '0';
        } else {
          offerBanner.classList.remove('banner-hidden');
          if (mainHeader) mainHeader.style.top = 'var(--banner-height, 0px)';
        }
        bannerTicking = false;
      });
      bannerTicking = true;
    }
  }, { passive: true });

  if (closeBanner && offerBanner) {
    closeBanner.addEventListener('click', () => {
      offerBanner.style.display = 'none';
      document.documentElement.style.setProperty('--banner-height', '0px');
      if (mainHeader) mainHeader.style.top = '0';
      sessionStorage.setItem('offerBannerDismissed', 'true');
    });
  }

  // Recalculate on resize
  window.addEventListener('resize', updateBannerHeight);
</script>
