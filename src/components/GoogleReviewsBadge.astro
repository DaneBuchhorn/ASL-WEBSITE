---
// Google Reviews Floating Badge
const googleBusinessUrl = 'https://share.google/t77wsy7F6lPBVbll1';
const rating = 5.0;
const reviewCount = 14;
---

<a
  href={googleBusinessUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="google-badge"
  aria-label={`Rated ${rating} out of 5 on Google - Read our ${reviewCount} reviews`}
>
  <div class="google-badge-inner">
    <!-- Google "G" logo -->
    <div class="google-badge-logo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
    </div>

    <!-- Rating number -->
    <span class="google-badge-rating">{rating.toFixed(1)}</span>

    <!-- Stars -->
    <div class="google-badge-stars">
      {Array.from({ length: 5 }).map(() => (
        <svg width="14" height="14" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#FBBC05"/>
        </svg>
      ))}
    </div>

    <!-- Review count -->
    <span class="google-badge-count">({reviewCount})</span>
  </div>
</a>

<style>
  .google-badge {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: var(--white);
    border-radius: var(--radius-full);
    padding: 10px 18px;
    text-decoration: none;
    z-index: 9998;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    animation: badgeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1s both;
  }

  .google-badge:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16), 0 0 0 1px rgba(0, 0, 0, 0.06);
    color: inherit;
  }

  @keyframes badgeSlideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .google-badge-inner {
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .google-badge-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .google-badge-rating {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--black);
    line-height: 1;
  }

  .google-badge-stars {
    display: flex;
    align-items: center;
    gap: 1px;
  }

  .google-badge-stars svg {
    display: block;
  }

  .google-badge-count {
    font-size: 0.8125rem;
    color: #666;
    font-weight: 500;
    line-height: 1;
  }

  /* Tablet */
  @media (max-width: 768px) {
    .google-badge {
      bottom: 18px;
      right: 18px;
      padding: 8px 14px;
    }

    .google-badge-logo svg {
      width: 18px;
      height: 18px;
    }

    .google-badge-stars svg {
      width: 12px;
      height: 12px;
    }

    .google-badge-rating {
      font-size: 0.875rem;
    }

    .google-badge-count {
      font-size: 0.75rem;
    }
  }

  /* Small mobile */
  @media (max-width: 480px) {
    .google-badge {
      bottom: 14px;
      right: 14px;
      padding: 7px 12px;
      gap: 6px;
    }

    .google-badge-inner {
      gap: 6px;
    }

    .google-badge-logo svg {
      width: 16px;
      height: 16px;
    }

    .google-badge-stars svg {
      width: 11px;
      height: 11px;
    }

    .google-badge-count {
      display: none;
    }
  }
</style>
