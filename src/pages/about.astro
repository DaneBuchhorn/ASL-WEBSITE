---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import heroImage from '../../public/assets/images/general/Modern Home All Seasons Living.webp';

export const prerender = true;

const pageTitle = 'About Us | All Seasons Living | Australian Owned Home Improvements';
const pageDescription = 'Over 15 years of experience delivering quality home improvement solutions across Canberra. Australian owned and committed to local quality.';

// Organization Schema for SEO
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'All Seasons Living',
  description: pageDescription,
  url: 'https://allseasonsliving.com.au',
  telephone: '0261889606',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Canberra',
    addressRegion: 'ACT',
    addressCountry: 'AU'
  },
  foundingDate: '2010',
  slogan: 'Style You See · Comfort You Feel · Quality You Trust'
};

// Breadcrumb Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://allseasonsliving.com.au/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'About Us',
      item: 'https://allseasonsliving.com.au/about'
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-image-container">
      <Image
        src={heroImage}
        alt="Beautiful modern home in Canberra with outdoor living improvements by All Seasons Living"
        class="hero-image"
        loading="eager"
        width={1920}
        height={1080}
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <div class="container">
        <p class="hero-label">About All Seasons Living</p>
        <h1>Style You See · Comfort You Feel · Quality You Trust</h1>
        <p class="hero-subtitle">Over 15 years helping Canberra families transform their homes with Australian-made solutions built to last.</p>
      </div>
    </div>
  </section>

  <!-- Our Story Section -->
  <section class="story-section">
    <div class="container">
      <div class="story-grid">
        <div class="story-content">
          <h2>Proudly Australian Owned.<br>Committed to Local Quality.</h2>
          <p>At All Seasons Living, we believe your home should be a place of comfort, security, and effortless style. With over 15 years of experience in the home improvement industry, our team has helped hundreds of Australian families transform their homes with solutions that are practical, durable, and designed to last.</p>
          <p>From roller shutters that provide security and insulation, to artificial lawns that take the hassle out of maintenance, to outdoor blinds that elevate your lifestyle — we specialise in products that add real value to your home.</p>
          <p>What sets us apart isn't just our experience, but our commitment. Every project starts with listening to you — your home, your lifestyle, your vision. From there, we design and deliver tailored solutions backed by expert advice, quality workmanship, and personalised service from start to finish.</p>
        </div>
        <div class="story-image">
          <img
            src="/assets/images/roller-shutters/ASL Shutters.webp"
            alt="All Seasons Living roller shutters installed on a modern Canberra home"
            loading="lazy"
            width="600"
            height="600"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number">15+</span>
          <span class="stat-label">Years Experience</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">5.0</span>
          <span class="stat-label">Google Rating</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">100%</span>
          <span class="stat-label">Australian Owned</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">FREE</span>
          <span class="stat-label">Measure & Quote</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Promise Section -->
  <section class="promise-section">
    <div class="container">
      <h2 class="section-title">Our Promise is Simple</h2>
      <div class="promise-cards">
        <div class="promise-card">
          <div class="promise-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              <path d="M9 12l2 2 4-4"></path>
            </svg>
          </div>
          <h3>Quality You Can Trust</h3>
          <p>Premium products built to withstand Australian conditions, backed by comprehensive manufacturer warranties of up to 15 years.</p>
        </div>

        <div class="promise-card">
          <div class="promise-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 6v6l4 2"></path>
            </svg>
          </div>
          <h3>Service That Cares</h3>
          <p>From the initial consultation to final installation, we're with you every step of the way with personalised attention and expert guidance.</p>
        </div>

        <div class="promise-card">
          <div class="promise-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <h3>Value That Lasts</h3>
          <p>Practical upgrades that improve daily living, reduce energy costs, and boost your property's appeal for years to come.</p>
        </div>
      </div>
      <div class="promise-footer">
        <p>We're not just selling products — we're helping you create a home you love to live in, all year round.</p>
      </div>
    </div>
  </section>

  <!-- Products Overview -->
  <section class="products-overview">
    <div class="container">
      <h2 class="section-title">What We Do</h2>
      <div class="products-grid">
        <a href="/outdoor-blinds" class="product-overview-card">
          <div class="product-overview-image">
            <img src="/assets/images/outdoor-blinds/Outdoor Motorised Blinds.webp" alt="Outdoor motorised blinds installed on Canberra patio" loading="lazy" width="600" height="400" />
          </div>
          <div class="product-overview-body">
            <h3>Outdoor Blinds</h3>
            <p>Transform your outdoor area into a year-round living space with motorised straight drop blinds.</p>
          </div>
        </a>
        <a href="/roller-shutters" class="product-overview-card">
          <div class="product-overview-image">
            <img src="/assets/images/roller-shutters/All Seasons Living -Roller Shutters.webp" alt="Insulated roller shutters on modern home" loading="lazy" width="600" height="400" />
          </div>
          <div class="product-overview-body">
            <h3>Roller Shutters</h3>
            <p>Enhance security, insulation, and noise reduction with Australian-made aluminium roller shutters.</p>
          </div>
        </a>
        <a href="/artificial-lawn" class="product-overview-card">
          <div class="product-overview-image">
            <img src="/assets/images/artificial-lawn/Artificial-lawn-asl-media.webp" alt="Lush artificial lawn installed in Canberra backyard" loading="lazy" width="600" height="400" />
          </div>
          <div class="product-overview-body">
            <h3>Artificial Lawn</h3>
            <p>Premium, pet-friendly artificial grass — no mowing, no watering, green all year round.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Australian Made Section -->
  <section class="australian-section">
    <div class="container">
      <div class="australian-content">
        <img src="/assets/images/outdoor-blinds/Australian Made.png" alt="Australian Made logo" class="australian-icon" loading="lazy" />
        <h2>Over 15 Years of Excellence</h2>
        <p>As a proudly Australian owned and operated business, we understand the unique needs of local homeowners. Our experience across hundreds of projects has refined our approach to delivering solutions that truly work for Australian homes and lifestyles.</p>
        <div class="cta-buttons">
          <button class="btn btn-primary quote-trigger">Get Your Free Quote</button>
          <a href="tel:0261889606" class="btn btn-outline-white" data-location="about-cta">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            (02) 6188 9606
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ============================
     HERO SECTION
     ============================ */
  .hero-section {
    position: relative;
    height: 100vh;
    height: 100dvh;
    min-height: 580px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-image-container {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom,
      rgba(0,0,0,0.35) 0%,
      rgba(0,0,0,0.4) 30%,
      rgba(0,0,0,0.5) 60%,
      rgba(0,0,0,0.65) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 2rem 1rem;
    max-width: 850px;
  }

  .hero-label {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--yellow);
    margin-bottom: 1rem;
  }

  .hero-content h1 {
    font-size: clamp(1.75rem, 5vw, 3rem);
    color: var(--white);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: rgba(255,255,255,0.9);
    line-height: 1.6;
    max-width: 650px;
    margin: 0 auto;
  }

  /* ============================
     OUR STORY
     ============================ */
  .story-section {
    padding: 5rem 0;
    background: var(--cream);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .story-content h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--olive-green);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 2rem;
  }

  .story-content p {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--black);
    opacity: 0.85;
    margin-bottom: 1.25rem;
  }

  .story-content p:last-child {
    margin-bottom: 0;
  }

  .story-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.12);
  }

  .story-image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  /* ============================
     STATS BAR
     ============================ */
  .stats-section {
    padding: 3rem 0;
    background: var(--olive-green);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 1rem;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--white);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255,255,255,0.8);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ============================
     OUR PROMISE
     ============================ */
  .promise-section {
    padding: 5rem 0;
    background: var(--white);
  }

  .section-title {
    text-align: center;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    color: var(--olive-green);
    margin-bottom: 3rem;
    font-weight: 700;
  }

  .promise-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .promise-card {
    background: var(--light-sage);
    padding: 2rem 1.5rem;
    border-radius: var(--radius-lg);
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .promise-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .promise-icon {
    margin: 0 auto 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: var(--white);
    border-radius: 50%;
    color: var(--olive-green);
  }

  .promise-card h3 {
    font-size: 1.25rem;
    color: var(--olive-green);
    margin-bottom: 0.75rem;
    font-weight: 700;
  }

  .promise-card p {
    color: var(--black);
    opacity: 0.8;
    line-height: 1.6;
    font-size: 1rem;
  }

  .promise-footer {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }

  .promise-footer p {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--black);
    font-weight: 600;
    opacity: 0.85;
  }

  /* ============================
     PRODUCTS OVERVIEW
     ============================ */
  .products-overview {
    padding: 5rem 0;
    background: var(--cream);
  }

  .products-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .product-overview-card {
    display: block;
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    border: 2px solid rgba(90,110,69,0.08);
    transition: all 0.3s ease;
  }

  .product-overview-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  }

  .product-overview-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .product-overview-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product-overview-card:hover .product-overview-image img {
    transform: scale(1.05);
  }

  .product-overview-body {
    padding: 1.5rem;
  }

  .product-overview-body h3 {
    font-size: 1.25rem;
    color: var(--olive-green);
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .product-overview-body p {
    font-size: 0.9375rem;
    color: var(--black);
    opacity: 0.8;
    line-height: 1.6;
  }

  /* ============================
     AUSTRALIAN SECTION
     ============================ */
  .australian-section {
    padding: 5rem 0;
    background: var(--olive-green);
  }

  .australian-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    color: var(--white);
  }

  .australian-icon {
    width: 130px;
    height: auto;
    margin: 0 auto 1.5rem;
    display: block;
  }

  .australian-content h2 {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    color: var(--white);
    margin-bottom: 1.25rem;
    font-weight: 700;
  }

  .australian-content p {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.92);
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-outline-white {
    background: transparent;
    color: var(--white);
    border: 2px solid var(--white);
    padding: 0.875rem 2rem;
    font-size: 1rem;
    font-weight: 700;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .btn-outline-white:hover {
    background: var(--white);
    color: var(--olive-green);
  }

  /* ============================
     TABLET (768px+)
     ============================ */
  @media (min-width: 768px) {
    .story-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
    }

    .promise-cards {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .products-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .product-overview-image {
      height: 220px;
    }
  }

  /* ============================
     DESKTOP (1025px+)
     ============================ */
  @media (min-width: 1025px) {
    .story-section {
      padding: 6rem 0;
    }

    .promise-section {
      padding: 6rem 0;
    }

    .products-overview {
      padding: 6rem 0;
    }

    .product-overview-image {
      height: 260px;
    }
  }
</style>
